PORT=8000
BASE_URL=http://localhost:8000
APP_NAME="Hono Base Postgres"

# App Locale & Timezone Configuration
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# PostgreSQL Database Configuration
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=hono_base
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_EXPIRES_IN=7d

# Better Auth Configuration
# Generate a secret: bun x better-auth secret
BETTER_AUTH_SECRET=your_better_auth_secret_minimum_32_characters_long
BETTER_AUTH_COOKIE_DOMAIN=localhost
BETTER_AUTH_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Social OAuth Credentials (Optional)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
