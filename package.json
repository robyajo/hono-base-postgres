{
  "name": "hono-base-postgres",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "tsc && cp src/index.html dist/src/index.html",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "collection": "tsx scripts/generate-collection.ts",
    "collection:watch": "tsx scripts/generate-collection.ts --watch"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@hono/standard-validator": "^0.2.3",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.8.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "tsx": "^4.23.1"
  }
}