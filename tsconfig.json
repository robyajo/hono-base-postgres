{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "verbatimModuleSyntax": true,
    "moduleResolution": "bundler",
    "types": [
      "bun"
    ],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "jsxImportSource": "hono/jsx"
  },
  "exclude": [
    "node_modules"
  ]
}